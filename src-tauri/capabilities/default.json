{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the companion window",
  "windows": ["companion"],
  "remote": {
    "urls": ["https://opencraftai.com/**"]
  },
  "permissions": [
    "core:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "store:default",
    "updater:default",
    "process:allow-restart",
    { "identifier": "opener:allow-open-url", "allow": [{ "url": "https://opencraftai.com/**" }] }
  ]
}
