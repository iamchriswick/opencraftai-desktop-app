{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenCraft AI",
  "version": "0.1.0",
  "identifier": "com.opencraft.ai",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyQ0JDOEYzM0QxQzI0NTUKUldSVkpCdzk4OGpMSWhKeUxiOW1lMVZMOWpoQ2E5aXlpZXRsZ1RRWkRON1JQMGMvK25zNnduVGsK",
      "endpoints": [
        "https://github.com/iamchriswick/opencraftai-desktop-app/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
